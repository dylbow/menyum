{
  "name": "menyum",
  "version": "1.0.0",
  "description": "Your favorite orders, always ready",
  "main": "index.html",
  "scripts": {
    "dev": "live-server --port=8401",
    "build": "echo 'Build complete'",
    "deploy": "./deploy.sh",
    "cap:init": "npx cap init Menyum com.dylbow.menyum --web-dir=.",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android"
  },
  "keywords": [
    "food",
    "orders",
    "restaurants",
    "pwa"
  ],
  "author": "Dylan Bowman",
  "license": "PRIVATE",
  "devDependencies": {
    "live-server": "^1.2.2"
  },
  "dependencies": {
    "@capacitor/core": "^5.0.0",
    "@capacitor/cli": "^5.0.0",
    "@capacitor/ios": "^5.0.0",
    "@capacitor/android": "^5.0.0"
  }
}
